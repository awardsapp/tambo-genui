{
  "extends": "@workspace/typescript-config/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2023",
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "noImplicitAny": false,
    "moduleResolution": "node",
    "module": "commonjs",
    "customConditions": null,
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "@workspace-cloud/backend": ["../../packages/backend/src"],
      "@workspace-cloud/core": ["../../packages/core/src"],
      "@workspace-cloud/db": ["../../packages/db/src"],
      "@workspace-cloud/testing": ["../../packages/testing/src"]
    }
  }
}
