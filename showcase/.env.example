# Genui API Configuration
# Get your API key from https://console.genui.co
NEXT_PUBLIC_GENUI_API_KEY=your_api_key_here

# Optional: Custom Genui API URL (for development/self-hosting)
# NEXT_PUBLIC_GENUI_API_URL=https://api.genui.co

# Optional: PostHog Analytics (omit for OSS deployments)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com